# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Master key for the proxy. Clients must send this as the API key.
# Must start with "sk-". Generate one with: openssl rand -hex 24
LITELLM_MASTER_KEY=sk-change-me

# Salt used to encrypt provider API keys stored in the database.
# Generate one with: openssl rand -hex 32
# Set this BEFORE storing any model credentials and never change it afterwards,
# or previously-encrypted secrets become unrecoverable.
LITELLM_SALT_KEY=change-me

# (Optional) UI login for the admin dashboard at http://localhost:4000/ui
UI_USERNAME=admin
UI_PASSWORD=change-me

# Postgres password. Required by docker-compose.prod.yml (the production VPS
# deploy); the local docker-compose.yml ignores it and uses a built-in default.
# Generate one with: openssl rand -hex 32
POSTGRES_PASSWORD=change-me

# --- Provider API keys (only the ones you actually use are required) ---
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
